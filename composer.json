{
    "name": "philiprehberger/laravel-api-versioning",
    "description": "Laravel middleware for API versioning with multi-source resolution from headers, Accept vendor types, and URL path segments.",
    "keywords": ["laravel", "api", "versioning", "middleware", "rest"],
    "license": "MIT",
    "authors": [
        {
            "name": "Philip Rehberger",
            "email": "me@philiprehberger.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/config": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\ApiVersioning\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\ApiVersioning\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhilipRehberger\\ApiVersioning\\ApiVersioningServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
